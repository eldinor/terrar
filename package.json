{
  "name": "terrar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    },
    "./builder": {
      "types": "./dist/builder.d.ts",
      "import": "./dist/builder.js"
    },
    "./builder/node": {
      "types": "./dist/builder-node.d.ts",
      "import": "./dist/builder-node.js"
    },
    "./builder/cli": {
      "types": "./dist/builder/terrainExportCli.d.ts",
      "import": "./dist/builder/terrainExportCli.js"
    },
    "./babylon": {
      "types": "./dist/babylon.d.ts",
      "import": "./dist/babylon.js"
    },
    "./demo": {
      "types": "./dist/demo-api.d.ts",
      "import": "./dist/demo-api.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "docs:api": "typedoc",
    "lint": "tsc -p tsconfig.json --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "export:terrain": "node dist/builder-cli.js"
  },
  "dependencies": {
    "@babylonjs/core": "8.54.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.2.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vitest": "^3.2.4"
  }
}
