{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src/main.ts",
    "src/builder.ts",
    "src/builder-node.ts",
    "src/babylon.ts",
    "src/demo-api.ts"
  ],
  "entryPointStrategy": "resolve",
  "tsconfig": "tsconfig.json",
  "out": "docs/typedoc",
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "readme": "README.md",
  "sort": [
    "source-order"
  ]
}
